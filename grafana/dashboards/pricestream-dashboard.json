{
  "title": "PriceStream Dashboard",
  "uid": "pricestream-dash",
  "panels": [
    {
      "type": "stat",
      "title": "Total Crypto Records Stored",
      "targets": [
        {
          "expr": "pricestream_records_stored_total",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "type": "timeseries",
      "title": "Background Fetch Rate (req/sec)",
      "targets": [
        {
          "expr": "rate(pricestream_fetch_success_total[1m])",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "rate(pricestream_fetch_empty_total[1m])",
          "legendFormat": "Empty",
          "refId": "B"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2,
            "drawStyle": "line"
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "API Request Rate (req/s)",
      "targets": [
        {
          "expr": "sum by (uri, status) (rate(http_server_requests_seconds_count{uri!~\".*actuator.*\"}[1m]))",
          "legendFormat": "{{uri}} - {{status}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "API Request Latency (ms)",
      "targets": [
        {
          "expr": "(sum by (uri) (rate(http_server_requests_seconds_sum{uri!~\".*actuator.*\"}[1m])) / sum by (uri) (rate(http_server_requests_seconds_count{uri!~\".*actuator.*\"}[1m]))) * 1000",
          "legendFormat": "{{uri}}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "fillOpacity": 15,
            "lineWidth": 2
          }
        }
      }
    }
  ],
  "schemaVersion": 39
}